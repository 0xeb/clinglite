From ad500e4d9adfe6fdb985198c1679cc8d3b731bff Mon Sep 17 00:00:00 2001
From: Elias Bachaalany <elias.bachaalany@gmail.com>
Date: Fri, 20 Feb 2026 17:17:48 -0800
Subject: [PATCH] Guard atexit interception with NoRuntime flag

Wrap the atexit interception block (__cxa_atexit, __dso_handle,
at_quick_exit, __dllonexit, _onexit) inside if(!NoRuntime), matching
the existing guard on the gCling/RuntimeUniverse preamble.

Without this, PCH files generated with -noruntime still contain
these declarations, causing redefinition errors when a consumer
interpreter loads the PCH and injects its own runtime.
---
 lib/Interpreter/Interpreter.cpp | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/lib/Interpreter/Interpreter.cpp b/lib/Interpreter/Interpreter.cpp
index f9f3767e..7e72f375 100644
--- a/lib/Interpreter/Interpreter.cpp
+++ b/lib/Interpreter/Interpreter.cpp
@@ -450,6 +450,7 @@ namespace cling {
       }
     }
 
+    if (!NoRuntime) {
     // Intercept all atexit calls, as the Interpreter and functions will be long
     // gone when the -native- versions invoke them.
 #if defined(__GLIBC__)
@@ -533,6 +534,7 @@ namespace cling {
       Strm << ";\n";
 #endif
 #endif
+    } // !NoRuntime (atexit interception)
 
     if (!SyntaxOnly) {
       // Override the helper symbols injected by GenericLLVMIRPlatformSupport,
-- 
